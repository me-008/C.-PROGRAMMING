#include <stdio.h>

int main()
{
    int choice;
    float a, b, result;

    printf("1. Addition\n");
    printf("2. Division\n");
    printf("3. Exit\n");

    printf("Enter your choice: ");
    scanf("%d", &choice);

    switch(choice)
    {
        case 1:
            printf("Enter two numbers: ");
            scanf("%f %f", &a, &b);
            result = a + b;
            printf("Addition = %.2f", result);
            break;

        case 2:
            printf("Enter two numbers: ");
            scanf("%f %f", &a, &b);
            result = a / b;
            printf("Division = %.2f", result);
            break;

        case 3:
            printf("Exit from program");
            break;

        default:
            printf("Invalid choice");
    }

    return 0;
}
